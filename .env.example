# ---- LLM Provider ----
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# ---- Neo4j Knowledge Graph ----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sentinel_pass

# ---- Vector Store (Chroma) ----
CHROMA_PERSIST_DIR=./data/chroma_store
CHROMA_COLLECTION_NAME=sentinel_documents

# ---- OCR ----
TESSERACT_CMD=/usr/bin/tesseract
OCR_LANGUAGE=eng

# ---- App ----
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:8501,http://frontend:8501

# ---- Confidence thresholds (used by agents to decide escalate-vs-answer) ----
MIN_ANSWER_CONFIDENCE=0.55
DRIFT_DETECTION_LOOKBACK_DAYS=730
